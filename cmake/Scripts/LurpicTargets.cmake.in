# LurpicUI package metadata target definitions.

if(NOT TARGET lurpic::metadata)
  add_library(lurpic::metadata INTERFACE IMPORTED)
endif()

set_target_properties(lurpic::metadata PROPERTIES
  INTERFACE_LURPICUI_VERSION "@LURPIC_PACKAGE_VERSION@"
  INTERFACE_LURPICUI_VCS_REVISION "@LURPIC_VCS_REVISION@"
  INTERFACE_LURPICUI_BUILD_TIMESTAMP "@LURPIC_BUILD_TIMESTAMP@"
  INTERFACE_LURPICUI_BACKEND_SOFTWARE "@LURPIC_BACKEND_SOFTWARE@"
  INTERFACE_LURPICUI_BACKEND_VULKAN "@LURPIC_BACKEND_VULKAN@"
  INTERFACE_LURPICUI_PLATFORM_LINUX "@LURPIC_PLATFORM_LINUX@"
  INTERFACE_LURPICUI_PLATFORM_ANDROID "@LURPIC_PLATFORM_ANDROID@"
  INTERFACE_LURPICUI_BUILD_EXAMPLES "@LURPIC_BUILD_EXAMPLES@"
  INTERFACE_LURPICUI_INCLUDE_TEMPLATE_THEMES "@LURPIC_INCLUDE_TEMPLATE_THEMES@"
  INTERFACE_LURPICUI_RELEASE_PACKAGE "@LURPIC_RELEASE_PACKAGE@"
)
