{
  "id": "basic.test",
  "display_name": "Basic Runtime Contract",
  "schema": "1.0",
  "family": "basic",
  "description": "Exercises the basic scene load path with explicit environment, capability, and expected-state metadata.",
  "required_scene": "basic",
  "environment": {
    "theme": "baseline",
    "density": "default",
    "backend": "software",
    "platform": "linux",
    "window_size": {
      "width": 800,
      "height": 600
    }
  },
  "capabilities": [
    "scene_load",
    "screenshots",
    "assertions"
  ],
  "expected_state": {
    "scene_id": "basic",
    "theme": "baseline",
    "density": "default"
  },
  "actions": [
    {
      "type": "scene_load",
      "params": {
        "scene": "basic"
      }
    },
    {
      "type": "wait_frames",
      "params": {
        "frames": 3
      }
    },
    {
      "type": "screenshot",
      "params": {
        "name": "initial_state"
      }
    }
  ],
  "assertions": [
    {
      "type": "scene_id",
      "params": {
        "expected": "basic"
      }
    },
    {
      "type": "theme_state",
      "params": {
        "expected": "baseline"
      }
    },
    {
      "type": "density_state",
      "params": {
        "expected": "default"
      }
    }
  ],
  "artifacts": [
    {
      "type": "screenshot",
      "name": "initial_state",
      "required": true
    }
  ],
  "tags": [
    "basic",
    "smoke-test",
    "runtime-contract"
  ]
}
